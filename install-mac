#!/bin/sh
set -e

echo "Building release bundle..."
cargo tauri build

BUNDLE_DIR="src-tauri/target/release/bundle/macos"

APP_PATH=$(find "$BUNDLE_DIR" -maxdepth 1 -name "*.app" -type d | head -n 1)

if [ -z "$APP_PATH" ]; then
    echo "Error: No .app bundle found in $BUNDLE_DIR after build."
    exit 1
fi

APP_NAME=$(basename "$APP_PATH")
DEST_PATH="/Applications/$APP_NAME"

echo "Installing $APP_NAME..."

if [ -d "$DEST_PATH" ]; then
    echo "Removing previous version from /Applications..."
    rm -rf "$DEST_PATH"
fi

cp -R "$APP_PATH" /Applications/

echo "Clearing quarantine attributes..."
xattr -cr "$DEST_PATH"

echo "Success: Built and installed to $DEST_PATH"
